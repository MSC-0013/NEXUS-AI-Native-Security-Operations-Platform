# NEXUS production environment template.
# Copy values into Vercel/Render dashboards. Do not commit real secrets.

# Frontend (Vercel)
VITE_API_URL=https://YOUR_RENDER_SERVICE.onrender.com
VITE_WS_URL=wss://YOUR_RENDER_SERVICE.onrender.com

# Backend (Render)
NODE_ENV=production
HOST=0.0.0.0
DATABASE_URL=postgresql://postgres:REDACTED@hayabusa.proxy.rlwy.net:37032/railway
CORS_ORIGIN=https://YOUR_VERCEL_APP.vercel.app,https://*.vercel.app

# JWT/auth
JWT_SECRET=replace-with-64-plus-random-characters
JWT_REFRESH_SECRET=replace-with-another-64-plus-random-characters
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Security/secrets
ENCRYPTION_KEY=replace-with-64-hex-characters
WEBHOOK_SIGNING_SECRET=replace-with-64-plus-random-characters
RATE_LIMIT_RPM_DEFAULT=300

# AI/Copilot
LLM_PROVIDER=none
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Optional object storage for future binary evidence uploads
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
